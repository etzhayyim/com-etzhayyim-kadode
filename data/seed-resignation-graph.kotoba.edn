 {:lx/id "r.messenger" :lx/kind :route :lx/label "kadode 使者 relay (意思の伝達のみ・交渉せず)" :route/actor :kadode-messenger :route/can-negotiate false :lx/sourcing :authoritative}
 {:lx/id "r.union" :lx/kind :route :lx/label "Labour union 団体交渉 (合同労組 / ユニオン)" :route/actor :labor-union :route/can-negotiate true :lx/sourcing :authoritative}
 {:lx/id "r.lawyer" :lx/kind :route :lx/label "Lawyer 弁護士 (紛争・請求・示談)" :route/actor :lawyer :route/can-negotiate true :lx/sourcing :authoritative}

